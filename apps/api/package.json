{
  "name": "@sm/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/copy-web.mjs",
