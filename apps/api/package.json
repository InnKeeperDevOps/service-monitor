    "@sm/domain": "workspace:*",
    "@sm/queue": "workspace:*",
    "@sm/web": "workspace:*",
    "@sm/worker": "workspace:*",
    "@sm/workflow-engine": "workspace:^",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.1",
    "supertest": "^7.1.0",
    "ws": "^8.18.2"
